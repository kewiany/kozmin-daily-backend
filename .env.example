# Local development
DATABASE_URL=postgresql+asyncpg://unievents:unievents@localhost:5432/unievents
SECRET_KEY=dev-secret-key-change-in-production
CORS_ORIGINS=*

# Production - set in Railway dashboard:
# DATABASE_URL      → from Neon: postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
# SECRET_KEY        → generate a strong random key
# CORS_ORIGINS      → https://your-app.vercel.app
# PORT              → auto-set by Railway
